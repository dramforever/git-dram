#!/usr/bin/env bash

set -e -u -o pipefail

usage() {
    echo "Usage:" >&2
    echo "  git stash-rebase push <upstream>" >&2
    echo "  git stash-rebase pop [<rebase-options>...]" >&2
    echo "  git stash-rebase abort" >&2
    exit 2
}

fail() {
    printf "%s\n" "$*" >&2
    exit 1
}

get_ref() {
    exec 7< <(git log --format="%B" -1 "$1")

    IFS=' ' read -r subject_key rest <&7

    if [[ "$subject_key" != "git-stash-rebase" ]]; then
        fail "fatal: Stash is not generated by git-stash-rebase"
    fi

    read <&7 # Blank line

    ref=""

    while read -r key value <&7; do
        case "$key" in
            ref)
                ref="$value"
                ;;
            *)
                # Something else? Ignore for now
                ;;
        esac
    done

    printf "%s" "$ref"

    exec 7<&-
}

gsr_push() {
    (( $# != 1 )) && usage

    upstream="$1"

    is_symbolic=1
    symbolic="$(git symbolic-ref -q --no-recurse --short HEAD)" || { is_symbolic=0; symbolic=HEAD; }

    args=()

    if (( is_symbolic )); then
        msg="git-stash-rebase $symbolic"
        args+=(-m "$msg" -m "ref $symbolic")
    else
        msg="git-stash-rebase $(git rev-parse HEAD)"
        args+=(-m "$msg")
    fi

    commit="$(git commit-tree "${args[@]}" -p "$1" -p "$symbolic" "$symbolic^{tree}")"

    git update-ref -m "$msg" --create-reflog refs/stash "$commit"

    git switch --detach "$upstream"
}

gsr_pop() {
    args=("$@")

    ref="$(get_ref "refs/stash")"

    if [[ "$ref" != "" ]]; then
        if [[ "$(git rev-parse "refs/stash^2")" != "$(git rev-parse "$ref")" ]]; then
            echo "git-stash-rebase: Branch $ref has changed, not updating" >&2
            ref=""
        fi
    fi

    if [[ "$ref" != "" ]]; then
        branch="$ref"
    else
        branch="refs/stash^2"
    fi

    if (( "${#args[@]}" == 0 )) && git replay --contained --onto HEAD "refs/stash^1"..."$branch" ; then
        if [[ "$ref" != "" ]]; then
            git switch "$branch"
        else
            git switch --detach "$branch"
        fi
        git reflog delete 'refs/stash@{0}'
    else
        echo "git-stash-rebase: Rebasing because git replay cannot be used." >&2
        echo "git-stash-rebase: Stash entry was kept. Use 'git stash drop' to discard it." >&2
        exec git rebase --update-refs "${args[@]}" --onto HEAD "refs/stash^1" "$branch"
    fi
}

gsr_abort() {
    (( $# != 0 )) && usage

    ref="$(get_ref "refs/stash")"

    if [[ "$ref" != "" ]]; then
        if [[ "$(git rev-parse "refs/stash^2")" != "$(git rev-parse "$ref")" ]]; then
            echo "git-stash-rebase: Branch $ref has changed, not updating" >&2
            ref=""
        fi
    fi

    if [[ "$ref" != "" ]]; then
        git switch "$ref"
    else
        git switch --detach "refs/stash^2"
    fi

    git reflog delete 'refs/stash@{0}'
}

(( $# < 1 )) && usage

subcmd="$1"
shift

case "$subcmd" in
    push)
        gsr_push "$@"
        ;;

    pop)
        gsr_pop "$@"
        ;;

    abort)
        gsr_abort "$@"
        ;;

    *)
        usage
        ;;
esac
